@article{Sparks1980,
title = "X-ray monochromator geometry for focusing synchrotron radiation above 10 keV",
journal = "Nuclear Instruments and Methods",
volume = "172",
number = "1",
pages = "237 - 242",
year = "1980",
issn = "0029-554X",
doi = "https://doi.org/10.1016/0029-554X(80)90640-0",
url = "https://doi.org/10.1016/0029-554X(80)90640-0",
author = "C.J. Sparks and B.S. Borie and J.B. Hastings",
abstract = "The relative merits of crystals versus moirrors for focusing synchrotron radiation at energies above 10 keV are explored. As mirrors have critical angles of reflection rypically 120 of the Bragg scattering angles for crystals, large mirror surface areas are required. Sagittal focusing is weak for mirrors and limits the amount of radiation intercepted. We show that crystals bent to a simple cylindrical curvature will accept large divergences of radiation for sagittal focusing. At a magnification near 13, the cylindrically curved crystals are shown to make the proper Bragg angle for energies above 5 keV and for divergences larger than 10 mrad and to produce X-ray beams which are approximately focused."
}

